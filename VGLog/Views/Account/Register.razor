@page "/account/register"
@using Microsoft.AspNetCore.Components.Forms
@using VGLog.Models
@inject HttpClient Http
@inject NavigationManager Navigation

<h3>Register</h3>

<EditForm Model="@model" OnValidSubmit="HandleRegister" FormName="RegisterForm">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div>
        <label>Email</label>
        <input @bind-="model.Email" />
    </div>

    <div>
        <label>Display name</label>
        <input @bind-="model.Displayname" />
    </div>

    <div>
        <label>Password</label>
        <input type="password" @bind="model.Password" />
    </div>

    <div>
        <label>Confirm password</label>
        <input type="password" @bind="model.ConfirmPassword" />
    </div>

    <button type="submit">Register</button>

</EditForm>

@code {
    private RegisterViewModel model = new();

    private async Task HandleRegister()
    {
        var response = await Http.PostAsJsonAsync("/account/register", model);
        Console.WriteLine($"Email: '{model.Email}', Password: '{model.Password}'");

        if (response.IsSuccessStatusCode)
        {
            Navigation.NavigateTo("/account/login", forceLoad: true);
        }
    }
}
