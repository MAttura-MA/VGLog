@page "/account/login"
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Web
@using Radzen
@using Radzen.Blazor
@using VGLog.Models.ViewModels
@using Microsoft.AspNetCore.Components.Forms

@inject NotificationService NotificationService

@*è possibile accedere a questa pagina anche da non autorizzati*@
@attribute [AllowAnonymous]

<PageTitle>VGLog - Login</PageTitle>

<div class="page-container">

    <h1 class="page-title">Login</h1>

    @*Form html normale con endpoint perche blazor non gestisce correttamente i cookie a differenza di asp.net identity*@
    <form method="post" action="/auth/login" class="form-container" id="loginForm" novalidate>
        @*generazione di un token antiforgery per proteggere da attacchi CSRF così un attaccante non può far submit del form da un altro sito poiché non ha questo token specifico*@
        <AntiforgeryToken />

        @if (!string.IsNullOrEmpty(ReturnUrl))
        {
            <input type="hidden" name="returnUrl" value="@ReturnUrl" />
        }

        <div class="form-group">
            <label>Email</label>
            <input name="Email" type="email" class="form-input" placeholder="Email" required />
            <span class="validation-message">The Email area can't be empty or invalid.</span>
        </div>

        <div class="form-group">
            <label>Password</label>
            <input name="Password" type="password" class="form-input" placeholder="Password" required />
            <span class="validation-message">The Password area can't be empty.</span>
        </div>

        <div class="form-group remember">
            <input name="RememberMe" type="checkbox" value="true" />
            <label>Remember me</label>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-primary">
                <span class="material-icons">login</span>
                Login
            </button>
            <a href="/account/register" class="btn-outline">
                <span class="material-icons">person_add</span>
                Register
            </a>
        </div>

    </form>

</div>



@code {
    [SupplyParameterFromQuery(Name = "returnUrl")]
    private string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery(Name = "error")]
    private string? Error { get; set; }

    // chiamato dopo che il componente è stato renderizzato perché ho la necessita di aspettare che il DOM (document object model) sia pronto per mostrare le notifiche
    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender && !string.IsNullOrEmpty(Error))
        {
            var message = Error switch
            {
                "invalid" => "Incorrect Email or password.",
                "invalidemail" => "Please enter a valid email address.",
                _ => "An error occurred."
            };

            NotificationService.Notify(NotificationSeverity.Error, "Error:", message);
        }
    }
}

<script>
    //validazione lato UX eseguita prima che il form venga inviato als erver, per far sapere all'utente subito cosa non vada
    document.getElementById("loginForm").addEventListener("submit", function (e) {

        const email = document.querySelector("input[name='Email']");
        const password = document.querySelector("input[name='Password']");

        const emailError = email.nextElementSibling;
        const passwordError = password.nextElementSibling;

        let valid = true;

        emailError.style.display = "none";
        passwordError.style.display = "none";

        if (!email.value.trim()) {
            emailError.style.display = "block";
            valid = false;
        }

        //evita password fatte di soli spazi bianchi
        if (!password.value.trim()) {
            passwordError.style.display = "block";
            valid = false;
        }

        if (!valid) {
            e.preventDefault(); // blocca il submit html in caso la validazione fallisse
        }

    });

</script>