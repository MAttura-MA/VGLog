@page "/account/login"

@using Microsoft.AspNetCore.Components.Forms
@using VGLog.Models
@using VGLog.Services.Interfaces

@inject NavigationManager Navigation
@inject IAccountService AccountService

<h3>Login</h3>

<EditForm Model="@model" OnSubmit="HandleLogin" FormName="LoginFormBob">

    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label for="email" class="form-label">Email</label>
        <InputText @bind-Value="model.Email" class="form-control input-text" id="Email" />
    </div>

    <div class="mb-3">
        <label for="password" class="form-label">Password</label>
        <InputText @bind-Value="model.Password" type="password" class="form-control input-text" id="Password" />
    </div>

    <div class="mb-3 form-check">
        <InputCheckbox class="form-check-input" @bind-Value="model.RememberMe" id="Remember" />
        <label for="remember" class="form-check-label">Remember me</label>
    </div>

    <div style="display:flex; gap: 16px; margin-top:12px; align-items: center">
        <RadzenButton ButtonType="ButtonType.Submit"
                      Text="Login"
                      Icon="login"
                      Style="background:#7c5cfc; border:none; padding: 0.6rem 1.5rem; border-radius: 8px; height:38px;" />

        <NavLink href="/account/register"
                 style="background:transparent; border: 1px solid #7c5cfc; color:#7c5cfc; padding: 0.6rem 1.5rem; border-radius: 8px; text-decoration:none; display:inline-flex; align-items:center; gap:4px; height:38px; box-sizing:border-box;">
            <RadzenIcon Icon="person_add" />
            Register
        </NavLink>
    </div>

</EditForm>


@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger mt-3">@errorMessage</div>
}

@code {
    [SupplyParameterFromForm]
    private LoginViewModel model { get; set; } = new LoginViewModel();

    private string errorMessage = "";

    private async Task HandleLogin()
    {

        var result = await AccountService.LoginAsync(model);

        if (result.Succeeded)
        {
            Navigation.NavigateTo("/", true);
        }
        else
        {
            errorMessage = "Login failed. Try again.";
        }
    }

    private void GoToRegister()
    {
        Navigation.NavigateTo("/account/register");
    }
}
