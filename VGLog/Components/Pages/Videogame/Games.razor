@page "/games"
@rendermode InteractiveServer
@attribute [Authorize]

@using System.Reflection
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Identity
@using VGLog.Components.Pages.Videogame
@using VGLog.Models
@using VGLog.Services.DTOs

@inject AuthenticationStateProvider AuthenticationStateProvider
@inject VGLog.Services.VideogameService VideogameService
@inject VGLog.Services.UserGamesService UserGamesService

@inject Radzen.NotificationService NotificationService
@inject DialogService DialogService
@inject UserManager<ApplicationUser> UserManager


<PageTitle>VGLog - My Games</PageTitle>

<h1>My Game Library</h1>
<p>Track, rate and manage your videogame journey</p>

<div>
    <p>Add a game</p>

    <div>
        <span>Game</span>
        <RadzenDropDown @bind-Value="@SelectedGameId"
                        Data="@AvailableGames"
                        TextProperty="Title"
                        ValueProperty="Id"
                        Placeholder="Search for a game..."
                        Change="@OnGameSelected"
                        Style="width: 300px; position: relative; visibility: visible">
        </RadzenDropDown>

        @if (SelectedGame != null)
        {
            <div class="mt-2">
                <span>Status</span>
                <RadzenDropDown @bind-Value="@PlayedOrNot"
                                Data="@GameStatuses"
                                Placeholder="Game Status"
                                TextProperty="Value"
                                ValueProperty="Key"
                                Style="width:180px" />
            </div>
            <div>
                <span>Hours played</span>
                <RadzenNumeric @bind-Value="@HoursPlayed"
                               Placeholder="0"
                               min="0"
                               Style="width:110px" />

            </div>


            @if (PlayedOrNot == GameStatus.Completed)
            {
                <div class="mt-2">

                    <span class="vg-label">Rating (1–10)</span>
                    <RadzenNumeric @bind-Value="SelectedRating"
                                   Min="1"
                                   Max="10"
                                   Style="width:90px" />
                </div>

                <div style="flex:1; min-width:200px">
                    <span>Notes</span>
                    <RadzenTextBox @bind-Value="@SelectedNotes"
                                   Placeholder="Your thoughts..."
                                   Style:"width:100%" />
                </div>

            }
            <div style="justify-content:flex-end">

                <RadzenButton Text="Add to the profile"
                              Click="AddGame"
                              ButtonStyle="ButtonStyle.Primary"
                              Style="margin-left:10px" />
            </div>
        }
    </div>
</div>

<div>
    <p>
        🗂️ Your library
        <span>@UserGames.Count games</span>
    </p>
</div>

<RadzenDataGrid Data="@UserGames"
                TItem="UserGame"
                AllowSorting="true"
                AllowPaging="true"
                PageSize="15"
                AllowColumnResize="true"
                ColumnResizeMode="DataGridColumnResizeMode.Fit"
                Style="width:100%"
                EmptyText="No games yet — add your first one above!">

    <Columns>

        <RadzenDataGridColumn TItem="UserGame" Property="Videogame.Title" Title="Game" Width="150px" MinWidth="120px" />

        <RadzenDataGridColumn TItem="UserGame" Property="GameStatus" Title="Game Status" Width="140px" MinWidth="120px" />

        <RadzenDataGridColumn TItem="UserGame" Property="PersonalRating" Title="Rating" Width="130px" MinWidth="120px">
            <Template Context="item">
                @if (item.PersonalRating.HasValue && item.PersonalRating > 0)
                {
                    <div style="display:flex; align-items:center; gap:.4rem">
                        <span style="font-weight:600; color:gold; font-size:.9rem">@item.PersonalRating</span>
                        <span style="color:var(--text-dim); font-size:.75rem">/ 10</span>
                        <span style="color:gold; font-size:.8rem">★</span>
                    </div>
                }
                else
                {
                    <span style="font-size:.8rem">—</span>
                }

            </Template>
        </RadzenDataGridColumn>

        <RadzenDataGridColumn TItem="UserGame" Property="HoursPlayed" Title="Hours played" Width="110px" MinWidth="120px">
            <Template Context="item">
                @if (item.HoursPlayed.HasValue && item.HoursPlayed > 0)
                {
                    <span>
                        @item.HoursPlayed h
                    </span>
                }

            </Template>
        </RadzenDataGridColumn>

        <RadzenDataGridColumn TItem="UserGame" Property="Notes" Title="Notes" Sortable="false" Width="140px" MinWidth="120px">
            <Template Context="item">
                @if (!string.IsNullOrWhiteSpace(item.Notes))
                {
                    <span title="@item.Notes">@item.Notes</span>
                }
                else
                {
                    <span style="font-size:.8rem">—</span>
                }
            </Template>
        </RadzenDataGridColumn>

        <RadzenDataGridColumn TItem="UserGame" 
                              Title="Actions" 
                              Sortable="false" 
                              Width="130px"
                              Frozen="true" 
                              FrozenPosition="FrozenColumnPosition.Right">
            <Template Context="item">
                <div>
                    <RadzenButton Text="Edit"
                                  Size="ButtonSize.Small"
                                  Click="@(async () => await OpenEditDialog(item))" />
                    @if (item.GameStatus != GameStatus.Dropped)
                    {
                        <RadzenButton Text="Drop"
                                      Size="ButtonSize.Small"
                                      Click="@(() => MarkAsdropped(item))"
                                      style="margin-left:1rem" />
                    }

                    <RadzenButton Text="Delete"
                                  Size="ButtonSize.Small"
                                  Click="@(() => DeleteUserGame(item))"
                                  style="margin-left:1rem" />
                </div>
            </Template>
        </RadzenDataGridColumn>

    </Columns>

</RadzenDataGrid>

@code {
    public List<Videogame> AvailableGames = new();
    private List<UserGame> UserGames { get; set; } = new();
    protected List<KeyValuePair<GameStatus, string>> GameStatuses =
    Enum.GetValues<GameStatus>()
        .Select(e => new KeyValuePair<GameStatus, string>(
            e,
            e.GetType()
             .GetMember(e.ToString())[0]
             .GetCustomAttribute<DisplayAttribute>()?.Name ?? e.ToString()
        ))
        .ToList();

    private UpdateUserGameDto EditDto { get; set; }

    private string? displayName;
    private AuthenticationState? authState;
    private ClaimsPrincipal? user;
    private GetUserGamesDto? ProfileData;
    private GameStatus PlayedOrNot { get; set; }
    private int? SelectedGameId { get; set; }
    private Videogame? SelectedGame { get; set; }
    private int SelectedRating { get; set; } = 1;
    private string? SelectedNotes { get; set; }
    private int? HoursPlayed { get; set; }
    private string? userId;


    protected override async Task OnInitializedAsync()
    {
        authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();

        user = authState.User;

        userId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        displayName = user.Claims
                .FirstOrDefault(c => c.Type == "DisplayName")?.Value ?? user.Identity.Name;

        AvailableGames = await VideogameService.GetAllAsync();

        await LoadUserGames();
    }

    private async Task LoadUserGames()
    {

        ProfileData = await UserGamesService.GetUserGamesByIdAsync(userId);
        UserGames = ProfileData.Games;

    }

    private void OnGameSelected(object value)
    {
        if (SelectedGameId.HasValue)
        {
            SelectedGame = AvailableGames.FirstOrDefault(g => g.Id == SelectedGameId.Value);
            SelectedRating = 1;
            SelectedNotes = "";
        }
        else
        {
            SelectedGame = null;
        }
        StateHasChanged();
    }

    private async Task AddGame()
    {
        if (SelectedGame == null) return;


        if (PlayedOrNot == GameStatus.Completed && (!HoursPlayed.HasValue || HoursPlayed.Value <= 0))
        {
            NotificationService.Notify(
                NotificationSeverity.Warning,
                "Invalid input",
                "For completed games, Hours played must be greater than 0"
            );
            return;
        }
        try
        {
            bool alreadyExists = UserGames.Any(ug => ug.Videogame.Id == SelectedGame.Id);

            if (alreadyExists == true)
            {
                NotificationService.Notify(
                    NotificationSeverity.Warning,
                    "Game already present",
                    $"{SelectedGame.Title} is already in your profile!");
                return;
            }

            await UserGamesService.AddGameToUserAsync(SelectedGame.Id, SelectedRating, SelectedNotes, user, PlayedOrNot, HoursPlayed);
            await LoadUserGames();

            NotificationService.Notify(NotificationSeverity.Success, "Game added correctly", $"You've added {SelectedGame.Title} to your profile!");

            SelectedGame = null;
            SelectedGameId = null;
            SelectedRating = 1;
            SelectedNotes = "";
            PlayedOrNot = default;
            HoursPlayed = null;


        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Errore", ex.Message);
        }
    }

    private async Task OpenEditDialog(UserGame item)
    {
        var result = await DialogService.OpenAsync<EditUserGameDialog>(
            "Edit hours",
            new Dictionary<string, object>
                            {
                { "UserGame", item }
                            });

        if (result == true)
        {
            await LoadUserGames();
        }
    }

    private async Task MarkAsdropped(UserGame item)
    {

        await UserGamesService.EditUserGameStatusAsync(item.Id, GameStatus.Dropped);

        item.GameStatus = GameStatus.Dropped;

        StateHasChanged();
    }

    private async Task DeleteUserGame(UserGame item)
    {
        bool? confirmed = await DialogService.Confirm(
                $"Are you sure you want to delete {item.Videogame.Title}?",
                "Confirm Delete",
                new ConfirmOptions() { OkButtonText = "Yes", CancelButtonText = "No" });

        if (!confirmed.HasValue || !confirmed.Value)
            return;

        await UserGamesService.DeleteUserGameAsync(item.Id);

        UserGames.Remove(item);

        StateHasChanged();

        NotificationService.Notify(NotificationSeverity.Success, "Deleted", $"{item.Videogame.Title} removed from your profile.");
    }
}