@page "/"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using VGLog.Components.Layout
@using VGLog.Models
@using VGLog.Models.ViewModels
@using VGLog.Services.DTOs
@using System.Security.Claims;

@inject AuthenticationStateProvider AuthenticationStateProvider

@inject IHttpContextAccessor HttpContextAccessor
@inject VGLog.Services.VideogameService VideogameService
@inject VGLog.Services.UserGamesService UserGamesService
@inject NavigationManager NavigationManager


<PageTitle>Home</PageTitle>



@if (isLoggedIn)
{
    <h1>Welcome back, <b>@displayName!</b></h1>

    <div class="stats-container">

        <RadzenCard Class="stat-card">
            <div class="stat-header text-primary">
                <span>Total Games</span>
            </div>
            <div class="stat-value text-dark">
                <RadzenIcon Icon="density_small" Class="stat-icon text-primary" />
                @ProfileData.Total
            </div>
        </RadzenCard>

        <RadzenCard Class="stat-card">
            <div class="stat-header text-success">
                <span>Completed</span>
            </div>
            <div class="stat-value text-dark">
                <RadzenIcon Icon="check_circle" Class="stat-icon text-success" />
                @ProfileData.Completed
            </div>
        </RadzenCard>

        <RadzenCard Class="stat-card">
            <div class="stat-header text-warning">
                <span>Playing</span>
            </div>
            <div class="stat-value text-dark">
                <RadzenIcon Icon="sports_esports" Class="stat-icon text-warning" />
                @ProfileData.Playing
            </div>
        </RadzenCard>

        <RadzenCard Class="stat-card">
            <div class="stat-header text-purple">
                <span>To Play</span>
            </div>
            <div class="stat-value text-dark">
                <RadzenIcon Icon="schedule" Class="stat-icon text-purple" />
                @ProfileData.ToPlay
            </div>
        </RadzenCard>

        <RadzenCard Class="stat-card">
            <div class="stat-header text-dark">
                <span>Hours Played</span>
            </div>
            <div class="stat-value text-dark">
                <RadzenIcon Icon="data_info_alert" Class="stat-icon text-dark" />
                @ProfileData.TotalHours
            </div>
        </RadzenCard>

    </div>

    <RadzenRow Style="padding-top:1rem" JustifyContent="JustifyContent.Start">

        @if (ChartData.Any())
        {

            <RadzenCard Title="Games Overview" Style="height: 370px; width: 33%">
                <div class="stat-value text-dark"> Games Overview</div>
                <RadzenChart>
                    <RadzenLegend Position="LegendPosition.Right" />
                    <RadzenPieSeries Data="@ChartData" Title="Games Overview" CategoryProperty="Status" ValueProperty="Value" Fills="@(new[] { "#2e7d32" , "#f9a825", "#7e57c2", "#424242"})">
                        <RadzenSeriesDataLabels Visible="true" />
                    </RadzenPieSeries>
                </RadzenChart>
            </RadzenCard>
        }

        <RadzenCard Style="height: 370px; width: 33%">
            <div class="stat-value text-dark"> 
                Recent Games
                <RadzenButton Text="See all games" Click="GoToAllGames" Style="margin-left:8rem; background-color:lightgray; color:black; border-radius:10px" />

            </div>


            <RadzenDataGrid Data="@LastFivePlayed" TItem="UserGame" Style="margin-left:-1rem" Class="recent-games-grid">
                <Columns>
                    <RadzenDataGridColumn TItem="UserGame" Title="" Width="60px">
                        <Template Context="game">
                            @if (game.Videogame?.Image != null)
                            {
                                <img src="data:image/jpeg;base64,@Convert.ToBase64String(game.Videogame.Image)"
                                style="width:40px; height:40px; object-fit:cover; border-radius:4px;" />
                            }
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="UserGame" Property="Videogame.Title" Title="" />
                    <RadzenDataGridColumn TItem="UserGame" Title="" Width="120px">
                        <Template Context="game">
                            <span style="@GetStatusStyle(game.GameStatus)">
                                @game.GameStatus
                            </span>
                        </Template>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>
        </RadzenCard>
    </RadzenRow>
}
else
{

    <h1>Welcome to VGLog!</h1>
    <p> Login/Register to see your games. </p>

}
@code
{
    private string? displayName;
    private bool isLoggedIn;
    private GetUserGamesDto? ProfileData;
    private List<UserGame> LastFivePlayed { get; set; } = new();
    //private List<UserGame> UserGames { get; set; } = new();
    private string? userId;
    private List<PieChartItems> ChartData = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;


        isLoggedIn = user.Identity?.IsAuthenticated ?? false;

        if (isLoggedIn)
        {
            userId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;

            if (!string.IsNullOrEmpty(userId))
            {
                ProfileData = await UserGamesService.GetUserGamesByIdAsync(userId);
                LastFivePlayed = await UserGamesService.LastGamesAdded(userId);

                //TODO - caricare solamente la lista PARZIALE dei giochi per quanto riguarda la dashboard, inutile caricarla tutta per poi mostrarne solo una parte
                //UserGames = ProfileData.Games;

                displayName = user.Claims
                .FirstOrDefault(c => c.Type == "DisplayName")?.Value ?? user.Identity.Name;

                if (ProfileData != null)
                {
                    ChartData = new List<PieChartItems>
                    {
                        new PieChartItems { Status = "Completed", Value = ProfileData.Completed},
                        new PieChartItems {Status = "Playing", Value = ProfileData.Playing},
                        new PieChartItems { Status = "To Play", Value = ProfileData.ToPlay},
                        new PieChartItems { Status = "Dropped", Value = ProfileData.Dropped}
                    }
                    .Where(x => x.Value > 0)
                    .ToList(); 
                }
            }
        }
    }

    protected void GoToAllGames()
    {
        NavigationManager.NavigateTo("/Account/Profile");
    }

    private string GetStatusStyle(GameStatus? status) => status switch
    {
        GameStatus.Completed => "background:rgb(25, 135, 84); color:#AFF0D2; padding:4px 0; border-radius:20px; font-size:0.85rem; width:80px; display:inline-block; text-align:center;",
        GameStatus.Playing => "background:#ffc107; color:#c69500; padding:4px 0; border-radius:20px; font-size:0.85rem; width:80px; display:inline-block; text-align:center;",
        GameStatus.Toplay => "background:mediumpurple; color:#43259a; padding:4px 0; border-radius:20px; font-size:0.85rem; width:80px; display:inline-block; text-align:center;",
        GameStatus.Dropped => "background:#6c6c6c; color:#000000; padding:4px 0; border-radius:20px; font-size:0.85rem; width:80px; display:inline-block; text-align:center;"
    };
}