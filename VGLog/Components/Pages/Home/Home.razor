@page "/"
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using VGLog.Components.Layout
@using VGLog.Components.Pages.Home.Profile
@using VGLog.Models
@using VGLog.Models.ViewModels
@using VGLog.Services.DTOs
@using System.Security.Claims;

@inject AuthenticationStateProvider AuthenticationStateProvider

@inject IHttpContextAccessor HttpContextAccessor
@inject VGLog.Services.VideogameService VideogameService
@inject VGLog.Services.UserGamesService UserGamesService
@inject NavigationManager NavigationManager


<PageTitle>VGLog - Home</PageTitle>



@if (isLoggedIn)
{
    <div class="h-welcome">
        <div class="h-welcome-left">
            <div class="h-welcome-avatar">
                @(displayName?[0].ToString().ToUpper())
            </div>
            <div class="h-welcome-text">
                <span class="h-welcome-greeting">Welcome back</span>
                <span class="h-welcome-name">@displayName</span>
            </div>
        </div>
        <span class="h-welcome-date">@DateTime.Now.ToString("dddd, dd MMMM yyyy")</span>
    </div>

    <div class="h-stats-grid">
        <div class="h-stat-card">
            <div class="h-stat-label blue">
                <RadzenIcon Icon="density_small" />
                Total Games
            </div>
            <div class="h-stat-value">@ProfileData?.Total</div>
        </div>
        <div class="h-stat-card">
            <div class="h-stat-label green">
                <RadzenIcon Icon="check_circle" />
                Completed
            </div>
            <div class="h-stat-value" style="color:#3ddc84">@ProfileData?.Completed</div>
        </div>
        <div class="h-stat-card">
            <div class="h-stat-label yellow">
                <RadzenIcon Icon="sports_esports" />
                Playing
            </div>
            <div class="h-stat-value" style="color:#f5c842">@ProfileData?.Playing</div>
        </div>
        <div class="h-stat-card">
            <div class="h-stat-label purple">
                <RadzenIcon Icon="schedule" />
                To Play
            </div>
            <div class="h-stat-value" style="color:#7c5cfc">@ProfileData?.ToPlay</div>
        </div>
        <div class="h-stat-card">
            <div class="h-stat-label muted">
                <RadzenIcon Icon="timer" />
                Hours Played
            </div>
            <div class="h-stat-value">@ProfileData?.TotalHours</div>
        </div>
    </div>
    
    <div class="h-bottom-grid">

        @if (ChartData.Any())
        {
            <div class="h-section">
                <div class="h-section-header">
                    <div class="h-section-title">
                        <div class="h-section-dot" style="background:#7c5cfc"></div>
                        Games Overview
                    </div>
                </div>
                <RadzenChart>
                    <RadzenLegend Position="LegendPosition.Right" />
                    <RadzenPieSeries Data="@ChartData"
                                     Title="Games Overview"
                                     CategoryProperty="Status"
                                     ValueProperty="Value"
                                     Fills="@(new[] { "#3ddc84", "#f5c842", "#7c5cfc", "#6b6b85" })">
                        <RadzenSeriesDataLabels Visible="true" />
                    </RadzenPieSeries>
                </RadzenChart>
            </div>
        }

        <div class="h-section">
            <div class="h-section-header">
                <div class="h-section-title">
                    <div class="h-section-dot" style="background:#fc5c7d"></div>
                    Recent Games
                </div>
                <button class="h-btn-ghost" @onclick="GoToAllGames">See all →</button>
            </div>

            @if (LastFivePlayed.Any())
            {
                @foreach (var game in LastFivePlayed)
                {
                    <div class="h-game-row">
                        @if (game.Videogame?.Image != null)
                        {
                            <img class="h-game-img"
                                 src="data:image/jpeg;base64,@Convert.ToBase64String(game.Videogame.Image)"
                                 alt="@game.Videogame.Title" />
                        }
                        else
                        {
                            <div class="h-game-img" style="display:flex;align-items:center;justify-content:center;font-size:18px;">🎮</div>
                        }
                        <span class="h-game-title">@game.Videogame?.Title</span>
                        <span class="h-status-badge @GetStatusClass(game.GameStatus)">
                            @game.GameStatus
                        </span>
                    </div>
                }
            }
            else
            {
                <div style="color:#6b6b85; font-size:14px; padding:16px 0; text-align:center;">
                    No games added yet.
                </div>
            }
        </div>

    </div>
}
else
{
    <div class="h-guest">
        <div class="h-guest-title">Welcome to VGLog</div>
        <p class="h-guest-sub">A videogame tracking Web App.</p>
        
        <div class="h-guest-sub" style="display: flex; flex-direction: row; gap: 2rem; align-items: start;">
            <div>
                <p>Tech stack:</p>
                <p>• ASP.NET aCore</p>
                <p>• Blazor Server</p>
                <p>• Entity Framework</p>
                <p>• Azure App Service</p>
                <p>• GitHub Actions CI/CD</p>
            </div>

            <div>
                <p>Features:</p>
                <p>• Game tracking</p>
                <p>• Completion statistics</p>
                <p>• User profile system</p>
                <p>• Image upload</p>
            </div>
        </div>
        <a href="https://github.com/MAttura-MA/VGLog/" target="_blank">
            <i class="fa-brands fa-github"></i>
            GitHub
        </a>
        <a href="/about">About</a>
    </div>
 
        @* <NavLink href="/account/login"
                 style="background:#7c5cfc; border:none; padding: 0.6rem 1.5rem; border-radius: 8px; height:38px; box-sizing:border-box; text-decoration:none; display:inline-flex; align-items:center; gap:4px; color:white; font-size:0.875rem; font-weight:500;">
            <RadzenIcon Icon="login" />
            Login
        </NavLink>

        <NavLink href="/account/register"
                 style="background:transparent; border: 1px solid #7c5cfc; color:#7c5cfc; padding: 0.6rem 1.5rem; border-radius: 8px; text-decoration:none; display:inline-flex; align-items:center; gap:4px; height:38px; box-sizing:border-box;">
            <RadzenIcon Icon="person_add" />
            Register
        </NavLink> *@
}
@code
{
    private string? displayName;
    private bool isLoggedIn;
    private GetUserGamesDto? ProfileData;
    private List<UserGame> LastFivePlayed { get; set; } = new();
    //private List<UserGame> UserGames { get; set; } = new();
    private string? userId;
    private List<PieChartItems> ChartData = new();
    

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;


        isLoggedIn = user.Identity?.IsAuthenticated ?? false;

        if (isLoggedIn)
        {
            userId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;

            if (!string.IsNullOrEmpty(userId))
            {
                ProfileData = await UserGamesService.GetUserGamesByIdAsync(userId);
                LastFivePlayed = await UserGamesService.LastGamesAdded(userId);

                displayName = user.Claims
                .FirstOrDefault(c => c.Type == "DisplayName")?.Value ?? user.Identity.Name;

                if (ProfileData != null)
                {
                    ChartData = new List<PieChartItems>
                    {
                        new PieChartItems { Status = "Completed", Value = ProfileData.Completed},
                        new PieChartItems {Status = "Playing", Value = ProfileData.Playing},
                        new PieChartItems { Status = "To Play", Value = ProfileData.ToPlay},
                        new PieChartItems { Status = "Dropped", Value = ProfileData.Dropped}
                    }
                    .Where(x => x.Value > 0)
                    .ToList(); 
                }
            }
        }
    }

    protected void GoToAllGames()
    {
        NavigationManager.NavigateTo("/Games");
    }

    private string GetStatusClass(GameStatus? status) => status switch
    {
        GameStatus.Completed => "h-status-completed",
        GameStatus.Playing => "h-status-playing",
        GameStatus.Toplay => "h-status-toplay",
        GameStatus.Dropped => "h-status-dropped",
        _ => ""
    };
}