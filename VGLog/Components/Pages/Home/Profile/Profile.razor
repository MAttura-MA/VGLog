@page "/account/profile"
@attribute [Authorize]
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using Radzen
@using Radzen.Blazor
@using System.Reflection
@using System.ComponentModel.DataAnnotations
@using System.Security.Claims
@using VGLog.Data
@using VGLog.Models
@using VGLog.Services
@using Microsoft.AspNetCore.Components.Authorization
@using VGLog.Services.DTOs
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject VGLog.Services.VideogameService VideogameService
@inject VGLog.Services.UserGamesService UserGamesService

@inject Radzen.NotificationService NotificationService
@inject DialogService DialogService
@inject UserManager<ApplicationUser> UserManager


<RadzenDialog />

<RadzenNotification />


<div>
    <RadzenCard Style="display:flex; align-items:center; gap:1.5rem; padding:1.5rem;">

        @if (!string.IsNullOrEmpty(avatarBase64))
        {
            <img src="@avatarBase64" style="width:256px; height:256px; border-radius:12px; object-fit:cover;" />
        }
        <div style="display:flex; flex-direction:column; gap:0.4rem; margin-bottom: 9rem">
            <h2 style="margin:0; font-size:4rem; font-weight:700;">@displayName</h2>
            <h3 style="margin:0; color:#666; font-size:0.9rem;">bioAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA futura</h3>

            <div style="display:flex; align-items:center; gap:0.5rem; font-size:0.85rem; color:#888;">
                <RadzenIcon Icon="calendar_today" Style="font-size:16px;" />
                <span>Joined: @* @user.JoinDate.ToString("MMMM dd, yyyy") *@ data iscrizione</span>
            </div>
        </div>
    </RadzenCard>
</div>

<div style="font-weight:700; font-size:2.5rem">Lifetime Stats</div>
<div class="stats-container" Style="margin-top:-0.5rem">
    <RadzenCard Class="stat-card" Style="width:20%">
        <div class="stat-header text-primary">
            <span>Total Games</span>
        </div>
        <div class="stat-value text-dark">
            <RadzenIcon Icon="density_small" Class="stat-icon text-primary" />
            @if (ProfileData != null)
            {
                @ProfileData.Total
            }
        </div>
    </RadzenCard>

    <RadzenCard Class="stat-card" Style="width:20%">
        <div class="stat-header text-success">
            <span>Completed</span>
        </div>
        <div class="stat-value text-dark">
            <RadzenIcon Icon="check_circle" Class="stat-icon text-success" />
            @if (ProfileData != null)
            {
                @ProfileData.Completed
            }
        </div>
    </RadzenCard>

    <RadzenCard Class="stat-card" Style="width:20%">
        <div class="stat-header text-dark">
            <span>Hours Played</span>
        </div>
        <div class="stat-value text-dark">
            <RadzenIcon Icon="data_info_alert" Class="stat-icon text-dark" />
            @if (ProfileData != null)
            {
                @ProfileData.TotalHours
            }
        </div>
    </RadzenCard>

    <RadzenCard Class="stat-card" Style="width:32%">
        <div class="stat-header text-dark">
            <span>Completion Rate</span>
        </div>
        <div class="stat-value text-dark">
            <RadzenIcon Icon="done_all" Class="stat-icon text-dark" />
            @completionRate%
        </div>
    </RadzenCard>
</div>
<div class="stats-container" Style="margin-top:1rem">
    <RadzenCard Class="stat-card" Style="width:32%">
        <div class="stat-header text-dark">
            <span>Average Rating</span>
        </div>
        <div class="stat-value text-dark">
            <RadzenIcon Icon="kid_star" Class="stat-icon text-dark" />
            @AvgRating
        </div>
    </RadzenCard>

    <RadzenCard Class="stat-card" Style="width:32%">
        <div class="stat-header text-dark">
            <span>Most played</span>
        </div>
        <div class="stat-value text-dark">
            <img src="data:image/jpeg;base64,@Convert.ToBase64String(MostPlayedGame.Videogame.Image)" style="width:55px; height:75px; object-fit:cover; border-radius:6px;" />
            <div style="display:flex; flex-direction:column; gap:0.2rem;">
                <span style="font-size:1rem; font-weight:700;">@MostPlayedGame.Videogame.Title</span>
                <span style="font-size:0.85rem; color:#555;">@MostPlayedGame.HoursPlayed hours</span>
            </div>
        </div>
    </RadzenCard>

    <RadzenCard Class="stat-card" Style="width:33%">
        <div class="stat-header text-dark">
            <span>Recently Completed</span>
        </div>
        <div class="stat-value text-dark">
            <img src="data:image/jpeg;base64,@Convert.ToBase64String(MostRecentlyCompletedGame.Videogame.Image)" style="width:55px; height:75px; object-fit:cover; border-radius:6px;" />
            <div style="display:flex; flex-direction:column; gap:0.2rem;">
                <span style="font-size:1rem; font-weight:700;">@MostRecentlyCompletedGame.Videogame.Title</span>
                <span style="font-size:0.85rem; color:#555;"> on @MostRecentlyCompletedGame.CompletedAt?.ToString("MMMM dd, yyyy") </span>
            </div>
        </div>
    </RadzenCard>
</div>

@code {
    private List<UserGame> UserGames { get; set; } = new();
    protected List<KeyValuePair<GameStatus, string>> GameStatuses =
    Enum.GetValues<GameStatus>()
        .Select(e => new KeyValuePair<GameStatus, string>(
            e,
            e.GetType()
             .GetMember(e.ToString())[0]
             .GetCustomAttribute<DisplayAttribute>()?.Name ?? e.ToString()
        ))
        .ToList();

    private UpdateUserGameDto EditDto { get; set; }

    private string? displayName;
    private AuthenticationState? authState;
    private ClaimsPrincipal? user;
    private GetUserGamesDto? ProfileData;
    private GameStatus PlayedOrNot { get; set; }
    private int? SelectedGameId { get; set; }
    private Videogame? SelectedGame { get; set; }
    private int SelectedRating { get; set; } = 1;
    private string? SelectedNotes { get; set; }
    private int? HoursPlayed { get; set; }
    private string? userId;
    private string? avatarBase64;



    protected override async Task OnInitializedAsync()
    {
        authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();

        user = authState.User;

        userId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        var currentUser = await UserManager.FindByIdAsync(userId);

        avatarBase64 = currentUser.Avatar != null
            ? $"data:image/png;base64,{Convert.ToBase64String(currentUser.Avatar)}"
            : null;

        displayName = user.Claims
                .FirstOrDefault(c => c.Type == "DisplayName")?.Value ?? user.Identity.Name;

        await LoadUserGames();
    }

    private async Task LoadUserGames()
    {
        try
        {
            ProfileData = await UserGamesService.GetUserGamesWithCounterAsync(userId);
            UserGames = ProfileData.Games;
        }
        catch
        {
            NotificationService.Notify(NotificationSeverity.Error, "Error", "There's an error retrieving the profile data, try again later");
        }

    }

    private async Task MarkAsdropped(UserGame item)
    {

        await UserGamesService.EditUserGameStatusAsync(item.Id, GameStatus.Dropped);

        item.GameStatus = GameStatus.Dropped;

        StateHasChanged();
    }

    private async Task DeleteUserGame(UserGame item)
    {
        bool? confirmed = await DialogService.Confirm(
                $"Are you sure you want to delete {item.Videogame.Title}?",
                "Confirm Delete",
                new ConfirmOptions() { OkButtonText = "Yes", CancelButtonText = "No" });

        if (!confirmed.HasValue || !confirmed.Value)
            return;

        await UserGamesService.DeleteUserGameAsync(item.Id);

        UserGames.Remove(item);

        StateHasChanged();

        NotificationService.Notify(NotificationSeverity.Success, "Deleted", $"{item.Videogame.Title} removed from your profile.");
    }

    private double? completionRate => ProfileData.Total > 0
    ? Math.Round((double)ProfileData.Completed / ProfileData.Total * 100, 1) : 0;

    private double AvgRating => Math.Round(UserGames
    .Where(x => x.PersonalRating.HasValue)
    .Select(x => x.PersonalRating!.Value)
    .DefaultIfEmpty(0)
    .Average(), 1);

    private UserGame? MostPlayedGame => UserGames
    .Where(x => x.HoursPlayed.HasValue)
    .OrderByDescending(x => x.HoursPlayed)
    .FirstOrDefault();

    private UserGame? MostRecentlyCompletedGame => UserGames
    .Where(x => x.CompletedAt.HasValue)
    .OrderByDescending(x => x.CompletedAt)
    .FirstOrDefault();
}
