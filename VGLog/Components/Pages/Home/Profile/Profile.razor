@page "/account/profile"
@attribute [Authorize]
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using Radzen
@using Radzen.Blazor
@using System.Reflection
@using System.ComponentModel.DataAnnotations
@using VGLog.Data
@using VGLog.Models
@using VGLog.Services
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject VGLog.Services.VideogameService VideogameService
@inject Radzen.NotificationService NotificationService
@inject VGLog.Data.AppDbContext AppDbContext
@inject NavigationManager NavigationManager
@inject DialogService DialogService


<RadzenDialog />

<RadzenNotification />

<h3>Profile</h3>
<h3>Add a played videogame</h3>

<RadzenDropDown @bind-Value="@SelectedGameId"
Data="@LoadGames"
TextProperty="Title"
ValueProperty="Id"
Placeholder="Select a game..."
Change="@OnGameSelected"
Style="width: 300px; position: relative; visibility: visible">
</RadzenDropDown>



@if (SelectedGame != null)
{
    <div class="mt-2">
        <RadzenDropDown
        @bind-Value="@PlayedOrNot"
        Data="@GameStatuses"
        Placeholder="Game Status"
        TextProperty="Value"
        ValueProperty="Key">
        </RadzenDropDown>
    </div>
    @if (PlayedOrNot == GameStatus.Playing)
    {
        <RadzenNumeric Placeholder="Add your time played" @bind-Value="@HoursPlayed" />

    }
    @if (PlayedOrNot == GameStatus.Completed)
    {
        <div class="mt-2">
            <RadzenLabel Text="Rating (1-10)" />
            <RadzenNumeric @bind-Value="SelectedRating" Min="1" Max="10" Style="width:80px" />
            <InputText Placeholder="Add your notes" @bind-Value="@SelectedNotes"/>
            <RadzenNumeric Placeholder="Add your time played" @bind-Value="@HoursPlayed" />

        </div>

    }
    <RadzenButton Text="Add to the profile" Click="AddGame" Style="margin-left:10px" />
}

<h3 class="mt-4">Your games</h3>
<RadzenDataGrid Data="@UserGames" TItem="UserGame">
    <Columns>
        <RadzenDataGridColumn TItem="UserGame" Property="Videogame.Title" Title="Game" />
        <RadzenDataGridColumn TItem="UserGame" Property="PersonalRating" Title="Rating" />
        <RadzenDataGridColumn TItem="UserGame" Property="Notes" Title="Notes" />
        <RadzenDataGridColumn TItem="UserGame" Property="GameStatus" Title="Game Status" />
        <RadzenDataGridColumn TItem="UserGame" Property="HoursPlayed" Title="Hours played" />
        <RadzenDataGridColumn TItem="UserGame" Title="Actions">
            <Template Context="item">
                <RadzenButton
                Text="Edit"
                Size="ButtonSize.Small"
                Click="@(async () => await OpenEditDialog(item))" />
            </Template>
        </RadzenDataGridColumn>


    </Columns>
</RadzenDataGrid>

@code {
    public List<Videogame> LoadGames = new();
    private List<UserGame> UserGames { get; set; } = new();
    protected List<KeyValuePair<GameStatus, string>> GameStatuses =
    Enum.GetValues<GameStatus>()
        .Select(e => new KeyValuePair<GameStatus, string>(
            e,
            e.GetType()
             .GetMember(e.ToString())[0]
             .GetCustomAttribute<DisplayAttribute>()?.Name ?? e.ToString()
        ))
        .ToList();

    private bool checkSelectedUserGame;

    private GameStatus PlayedOrNot { get; set; }
    private int? SelectedGameId { get; set; }
    private Videogame? SelectedGame { get; set; }
    private int SelectedRating { get; set; } = 1;
    private string? SelectedNotes { get; set; }
    private int? HoursPlayed { get; set; }

    protected override async Task OnInitializedAsync()
    {
        LoadGames = await VideogameService.GetAllAsync();
        await LoadUserGames();
    }

    private async Task LoadUserGames()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();

        var user = authState.User;

        UserGames = await VideogameService.GetUserGamesAsync(user);

    }

    private void OnGameSelected(object value)
    {
        if (SelectedGameId.HasValue)
        {
            SelectedGame = LoadGames.FirstOrDefault(g => g.Id == SelectedGameId.Value);
            SelectedRating = 1;
            SelectedNotes = "";
        }
        else
        {
            SelectedGame = null;
        }
        StateHasChanged();
    }

    private async Task AddGame()
    {
        if (SelectedGame == null) return;


        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            bool alreadyExists = UserGames.Any(ug => ug.Videogame.Id == SelectedGame.Id);

            if (alreadyExists == true)
            {
                NotificationService.Notify(
                    NotificationSeverity.Warning,
                    "Game already present",
                    $"{SelectedGame.Title} is already in your profile!");
                return;
            }

            await VideogameService.AddGameToUserAsync(SelectedGame.Id, SelectedRating, SelectedNotes, user, PlayedOrNot, HoursPlayed);

            NotificationService.Notify(NotificationSeverity.Success, "Game added correctly", $"You've added {SelectedGame.Title} to your profile!");

            SelectedGame = null;
            SelectedGameId = null;
            SelectedRating = 1;
            SelectedNotes = "";


            NavigationManager.NavigateTo(NavigationManager.Uri, forceLoad: true);
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Errore", ex.Message);
        }
    }

    private async Task EditHours(UserGame item)
    {
        await VideogameService.EditUserGame(item.Id, item.HoursPlayed);
    }

    private async Task OpenEditDialog(UserGame item)
    {
        var result = await DialogService.OpenAsync<EditUserGameDialog>(
            "Edit hours",
            new Dictionary<string, object>
            {
                { "UserGame", item }
            });

        if (result == true)
        {
            await LoadUserGames();
        }
    }

}
