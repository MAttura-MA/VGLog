
@using Microsoft.AspNetCore.Components.Authorization
@using VGLog.Components.Layout

@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IHttpContextAccessor HttpContextAccessor
@inject NavigationManager Navigation

@inherits LayoutComponentBase

<RadzenNotification />

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            @if (isLoggedIn)
            {
                <TopBar DisplayName="@displayName" />
            }
            else
            {
                <a class="topbar-auth-link" href="/account/login">Login</a>
                <a class="topbar-auth-btn" href="/account/register">Register</a>
            }
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool dropdownOpen = false;
    private string? displayName;
    private bool isLoggedIn;
    private string? antiForgeryToken;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        isLoggedIn = user.Identity?.IsAuthenticated ?? false;

        if (isLoggedIn)
        {
            displayName = user.Claims
                .FirstOrDefault(c => c.Type == "DisplayName")?.Value ?? user.Identity.Name;

            var antiforgery = HttpContextAccessor.HttpContext!.RequestServices
                .GetRequiredService<Microsoft.AspNetCore.Antiforgery.IAntiforgery>();

            antiForgeryToken = antiforgery.GetAndStoreTokens(HttpContextAccessor.HttpContext).RequestToken;
        }
    }

    void GoToProfile()
    {
        Navigation.NavigateTo("/account/profile");
    }

    private void CloseDropdown()
    {
        dropdownOpen = false;
    }

    private void ToggleDropdown()
{
    dropdownOpen = !dropdownOpen;
}

    [Inject]
    private IHttpContextAccessor httpContextAccessor { get; set; } = default!;
}