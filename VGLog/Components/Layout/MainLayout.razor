@using Microsoft.AspNetCore.Components.Authorization
@using VGLog.Components.Layout

@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IHttpContextAccessor HttpContextAccessor

@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            @if (isLoggedIn)
            {
                <p>Hi @displayName!</p>
                <form method="post" action="auth/logout">
                    <input type="hidden" name="__RequestVerificationToken" value="@antiForgeryToken" />
                    <button type="submit" class="btn btn-link">Logout</button>
                </form>

                <a href="/account/profile">Profile</a>
            }
            else
            {
                <a href="/account/login">Login</a>
                <a href="/account/register">Register</a>
            }

            <a href="https://learn.microsoft.com/aspnet/core/" target="_blank">About</a>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private string? displayName;
    private bool isLoggedIn;
    private string? antiForgeryToken;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        isLoggedIn = user.Identity?.IsAuthenticated ?? false;

        if (isLoggedIn)
        {
            displayName = user.Claims
                .FirstOrDefault(c => c.Type == "DisplayName")?.Value ?? user.Identity.Name;

            var antiforgery = HttpContextAccessor.HttpContext!.RequestServices
                .GetRequiredService<Microsoft.AspNetCore.Antiforgery.IAntiforgery>();

            antiForgeryToken = antiforgery.GetAndStoreTokens(HttpContextAccessor.HttpContext).RequestToken;
        }
    }

    [Inject]
    private IHttpContextAccessor httpContextAccessor { get; set; } = default!;
}