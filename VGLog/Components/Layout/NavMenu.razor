@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthenticationStateProvider

<RadzenNotification />

<div class="sidebar-logo">
    <span class="logo-vg">VG</span><span class="logo-log">LOG</span>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Dashboard
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="/games">
                <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span>Games
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="/Statistics">
                <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span>Statistics
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="/Friends">
                <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span>Friends
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="/achievements">
                <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span>Achievements
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="/settings">
                <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span>Settings
            </NavLink>
        </div>
    </nav>
</div>



@code
{
    private bool IsLoggedIn;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        IsLoggedIn = user.Identity != null && user.Identity.IsAuthenticated;
    }
}