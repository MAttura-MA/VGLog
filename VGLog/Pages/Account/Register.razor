@page "/account/register"

@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Routing
@using Microsoft.AspNetCore.Components.Web
@using Radzen
@using Radzen.Blazor
@using VGLog.Models
@using VGLog.Models.ViewModels
@using VGLog.Services.Interfaces

@inject NavigationManager Navigation
@inject IAccountService AccountService
@inject NotificationService NotificationService

<PageTitle>VGLog - Register</PageTitle>

<link rel="stylesheet" href="/app.css" />
<link rel="stylesheet" href="/css/login.css" />
<link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet" />


<div class="page-container">

    <h1 class="page-title">Register</h1>

    <div class="form-container">
        <RadzenTemplateForm TItem="RegisterViewModel"
                            Data="model"
                            Submit="HandleRegister">

            <div class="form-group">
                <RadzenLabel Text="Email" Component="Email" />
                <RadzenTextBox @bind-Value="model.Email"
                               Name="Email"
                               Placeholder="Email"
                               class="form-input"
                               Style="width:100%" />
                <RadzenRequiredValidator Component="Email"
                                         Text="Email is required"
                                         Style="color:#fc5c7d; font-size:0.8rem" />
                <RadzenEmailValidator Component="Email" Text="Email is not valid"/>
            </div>

            <div class="form-group">
                <RadzenLabel Text="Display name" Component="DisplayName" />
                <RadzenTextBox @bind-Value="model.DisplayName"
                               Name="DisplayName"
                               Placeholder="Display name"
                               class="form-input"
                               Style="width:100%" />
                <RadzenRequiredValidator Component="DisplayName"
                                         Text="Display name is required"
                                         Style="color:#fc5c7d; font-size:0.8rem" />
            </div>

            <div class="form-group">
                <RadzenLabel Text="Password" Component="Password" />
                <RadzenPassword @bind-Value="model.Password"
                                Name="Password"
                                Placeholder="Password"
                                class="form-input"
                                Style="width:100%" />
                <RadzenRequiredValidator Component="Password"
                                         Text="Password is required"
                                         Style="color:#fc5c7d; font-size:0.8rem" />
            </div>

            <div class="form-group">
                <RadzenLabel Text="Confirm password" Component="ConfirmPassword" />
                <RadzenPassword @bind-Value="model.ConfirmPassword"
                                Name="ConfirmPassword"
                                Placeholder="Confirm password"
                                class="form-input"
                                Style="width:100%" />
                <RadzenRequiredValidator Component="ConfirmPassword"
                                         Text="Confirm password is required"
                                         Style="color:#fc5c7d; font-size:0.8rem" />
            </div>

            <div class="form-actions">
                <RadzenButton ButtonType="ButtonType.Submit"
                              Text="Register"
                              Icon="person_add"
                              class="btn-primary" />

                <NavLink href="/account/login" class="btn-outline">
                    <span class="material-icons">login</span>
                    Login
                </NavLink>
            </div>

        </RadzenTemplateForm>
    </div>

</div>

@code {
    private RegisterViewModel model { get; set; } = new();
    private string errorMessage = "";

    private async Task HandleRegister()
    {
        errorMessage = "";

        if (model.Password != model.ConfirmPassword)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Error", "Passwords do not match.");
            return;
        }

        try
        {
            var response = await AccountService.RegisterAsync(model);

            if (response.Succeeded)
                Navigation.NavigateTo("/account/login");
            else
                errorMessage = string.Join(", ", response.Errors.Select(e => e.Description));
        }
        catch
        {
            NotificationService.Notify(NotificationSeverity.Error, "Error", "Registration failed. Try again later.");
        }
    }
}